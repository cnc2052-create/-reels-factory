# ──────────────────────────────────────────
# 필수 환경변수 — 이 파일을 .env 로 복사한 뒤 값을 채워 넣으세요
# ──────────────────────────────────────────

# [1] OpenAI API Key
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# [2] Buffer Access Token
# 발급: https://buffer.com/developers/api → Create App → Access Token
BUFFER_ACCESS_TOKEN=...

# [3] Buffer Instagram 채널 Profile ID
# 확인: https://api.bufferapp.com/1/profiles.json?access_token=YOUR_TOKEN
BUFFER_PROFILE_ID=...

# [4] 매일 예약 발행할 시각 (24시간제, UTC 기준)
# 예) 한국 오전 8시 = UTC 23 (전날)  →  실제 원하는 KST 시각 - 9
PUBLISH_HOUR_UTC=23
PUBLISH_MINUTE_UTC=0

# [5] (선택) 콘텐츠 카테고리 힌트 — GPT 기획 방향 지정
CONTENT_CATEGORY=자기계발/동기부여
